# ============================================
# LeyaOS — Git Ignore (v2.0)
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*

# --- Virtual environments ---
venv/
ENV/
env/
.venv/

# --- IDE / editors ---
.vscode/
.vs/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- LeyaOS: состояние мозга (КРИТИЧНО) ---
leya_brain/
*.pkl
*.pkl.tmp
*.pkl.hmac
chroma.sqlite3
chroma.sqlite3-journal

# --- LeyaOS: секреты и конфигурация окружения ---
.env
.env.local
.env.*.local
*.key
*.pem

# --- LeyaOS: логи ---
leya_consciousness.log
leya_consciousness.log.*
*.log

# --- LeyaOS: бэкапы и временные файлы ---
scripts/backup/
backups/
*.bak
*.tmp
*.temp

# --- Ollama локальные кэши (если случайно создаются в проекте) ---
ollama_cache/

# --- Node (если появится frontend-сборка) ---
node_modules/
package-lock.json
yarn.lock