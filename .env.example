# =================================================================================
# Конфигурация Леи (LeyaOS)
# Скопируйте этот файл в .env и настройте под себя:
# cp .env.example .env
# =================================================================================

# =================================================================================
# Режим работы интерфейса
# =================================================================================
# 1 = веб-интерфейс (FastAPI + WebSocket), 0 = CLI
LEYA_WEB=1

# =================================================================================
# Ollama (локальная LLM)
# =================================================================================
# URL Ollama API (по умолчанию http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Модель для использования (должна быть загружена через ollama pull)
# Рекомендуется: qwen2.5:14b-instruct-q3_K_M или qwen2.5:14b
LEYA_MODEL=qwen2.5:14b-instruct-q3_K_M

# =================================================================================
# Память и хранилище
# =================================================================================
# Директория для памяти Леи (ChromaDB + pickle)
# По умолчанию: ./leya_brain
LEYA_BRAIN_DIR=./leya_brain

# =================================================================================
# Логирование
# =================================================================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Файл для логов сознания
LOG_FILE=leya_consciousness.log

# =================================================================================
# Веб-интерфейс (если LEYA_WEB=1)
# =================================================================================
# Хост и порт веб-сервера
WEB_HOST=0.0.0.0
WEB_PORT=8000

# =================================================================================
# Драйвы и гомеостаз (экспериментальные параметры)
# =================================================================================
# Скорость метаболизма драйвов (0.0 - 1.0)
DRIVE_METABOLISM_RATE=0.01

# Период отдыха гомеостаза (в секундах)
HOMEOSTASIS_REST_PERIOD=60

# =================================================================================
# Безопасность (опционально)
# =================================================================================
# Секретный ключ для SoulCrypto (генерируется автоматически, если не указан)
# SOUL_SECRET_KEY=your-secret-key-here

# =================================================================================
# Инструменты (опционально)
# =================================================================================
# API ключи для внешних инструментов (если используются)
# WIKIPEDIA_API_KEY=
# REDDIT_CLIENT_ID=
# GITHUB_TOKEN=