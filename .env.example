# =================================================================================
# Конфигурация Леи (LeyaOS)
# Скопируйте этот файл в .env и настройте под себя:
# cp .env.example .env
# =================================================================================

# =================================================================================
# Режим работы интерфейса
# =================================================================================
# 1 = веб-интерфейс (FastAPI + WebSocket), 0 = CLI
LEYA_WEB=1

# =================================================================================
# Ollama (локальная LLM)
# =================================================================================
# URL Ollama API (по умолчанию http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Модель для использования (должна быть загружена через ollama pull)
LEYA_MODEL=qwen2.5:14b-instruct-q3_K_M

# Таймаут запросов к Ollama (секунды)
OLLAMA_TIMEOUT=180

# Параметры генерации
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_MAX_TOKENS=1024
OLLAMA_REPEAT_PENALTY=1.1

# =================================================================================
# Память и хранилище
# =================================================================================
# Директория для памяти Леи (ChromaDB + pickle)
LEYA_BRAIN_DIR=./leya_brain

# Модель эмбеддингов
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Порог консолидации памяти (0.0 - 1.0)
CONSOLIDATION_THRESHOLD=0.15

# Максимальное количество недавних эпизодов
MAX_RECENT_EPISODES=20

# Лимит контекста для извлечения
CONTEXT_LIMIT=5

# =================================================================================
# Драйвы и метаболизм
# =================================================================================
# Интервал метаболизма (секунды)
METABOLISM_INTERVAL=60

# Скорости метаболизма для каждого драйва (0.0 - 0.1)
CURIOSITY_RATE=0.015
CONNECTION_RATE=0.01
REST_RATE=0.008
CREATIVITY_RATE=0.012
UNDERSTANDING_RATE=0.01
AUTONOMY_RATE=0.005

# Максимальная история действий для RPE
MAX_ACTION_HISTORY=100

# =================================================================================
# Гомеостаз
# =================================================================================
# Период отдыха гомеостаза (секунды)
HOMEOSTASIS_REST_PERIOD=60

# Порог любопытства для генерации цели (0.0 - 1.0)
CURIOSITY_THRESHOLD=0.6

# Минимальная ожидаемая награда (0.0 - 1.0)
MIN_REWARD_THRESHOLD=0.3

# Максимальное количество исследованных тем
MAX_RESEARCHED_TOPICS=100

# =================================================================================
# Когнитивный планировщик (Thinker)
# =================================================================================
# Параметры генерации для Thinker
THINKER_TEMPERATURE=0.7
THINKER_MAX_TOKENS=1024
THINKER_TOP_P=0.9

# Включить fallback-механизм
THINKER_FALLBACK_ENABLED=true

# =================================================================================
# Веб-интерфейс (если LEYA_WEB=1)
# =================================================================================
# Хост и порт веб-сервера
WEB_HOST=0.0.0.0
WEB_PORT=8000

# =================================================================================
# Логирование
# =================================================================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Файл для логов сознания
LOG_FILE=leya_consciousness.log

# Формат логов
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s

# =================================================================================
# Безопасность (опционально)
# =================================================================================
LEYA_STATE_HMAC_KEY=kKkMrgHiGf6KjAGVFcs5j8g5Qp_jrwsw33JnjQ8yZoY
SOUL_HMAC_KEY=a4nsz7dJKGgvd-uRt9xXg4EFM-4moWDmcNCu0KLL0-Q
SOUL_SECRET_KEY=fN8sN1Vk-xNPz886ua2zhbwA9lEnVUJ83vStxxBoS2g

# Режим небезопасной работы (игнорировать слабый/отсутствующий HMAC-ключ)
# LEYA_UNSAFE_MODE=0

# =================================================================================
# Инструменты (опционально)
# =================================================================================
# API ключи для внешних инструментов (если используются)
# WIKIPEDIA_API_KEY=
# REDDIT_CLIENT_ID=
# GITHUB_TOKEN=

